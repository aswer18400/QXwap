# QXwap staging environment template
# Copy values into Render/GitHub/Supabase dashboards. Do not commit real secrets.

# Backend / Render
NODE_ENV=production
PORT=8787
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
SESSION_SECRET=replace-with-output-from-pnpm-secret-session
FRONTEND_ORIGIN=https://aswer18400.github.io

# Uploads / Supabase Storage
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key-backend-only
STORAGE_BUCKET=qxwap

# Frontend / GitHub Pages repository variable or secret
API_BASE_URL=https://YOUR_RENDER_SERVICE.onrender.com/api
