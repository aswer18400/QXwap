{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "QXwap API (Express + PGlite)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@workspace/api-server", "dev"],
      "port": 8787,
      "env": {
        "PGLITE_DATA_DIR": ".data/qxwap-pglite-parity"
      }
    },
    {
      "name": "QXwap Web (Vite)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@workspace/web-app", "dev"],
      "port": 5173
    }
  ]
}
